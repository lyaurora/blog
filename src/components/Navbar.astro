---
import { Icon } from "astro-icon/components";
import { navBarConfig, siteConfig } from "../config";
import { LinkPresets } from "../constants/link-presets";
import { LinkPreset, type NavBarLink } from "../types/config";
import { url } from "../utils/url-utils";
import LightDarkSwitch from "./LightDarkSwitch.svelte";
import Search from "./Search.svelte";
import DisplaySettings from "./widget/DisplaySettings.svelte";
import NavMenuPanel from "./widget/NavMenuPanel.astro";

const className = Astro.props.class;
const pagefindScriptUrl = url("/pagefind/pagefind.js");

let links: NavBarLink[] = navBarConfig.links.map(
	(item: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof item === "number") {
			return LinkPresets[item];
		}
		return item;
	},
);
---
<div id="navbar" class="z-50 onload-animation">
    <div class="absolute h-8 left-0 right-0 -top-8 bg-[var(--card-bg)] transition"></div> <!-- used for onload animation -->
    <div class:list={[
        className,
        "card-base !overflow-visible max-w-[var(--page-width)] h-[4.5rem] !rounded-t-none mx-auto flex items-center justify-between px-4"]}>
        <a href={url('/')} class="btn-plain scale-animation rounded-lg h-[3.25rem] px-5 font-bold active:scale-95">
            <div class="flex flex-row text-[var(--primary)] items-center text-md">
                <Icon name="material-symbols:home-outline-rounded" class="text-[1.75rem] mb-1 mr-2" />
                {siteConfig.title}
            </div>
        </a>
        <div class="hidden md:flex">
            {links.map((l) => {
                return <a aria-label={l.name} href={l.external ? l.url : url(l.url)} target={l.external ? "_blank" : null}
                          class="btn-plain scale-animation rounded-lg h-11 font-bold px-5 active:scale-95"
                >
                    <div class="flex items-center">
                        {l.name}
                        {l.external && <Icon name="fa6-solid:arrow-up-right-from-square" class="text-[0.875rem] transition -translate-y-[1px] ml-1 text-black/[0.2] dark:text-white/[0.2]"></Icon>}
                    </div>
                </a>;
            })}
        </div>
        <div class="flex">
            <!--<SearchPanel client:load>-->
            <Search client:load></Search>
            {!siteConfig.themeColor.fixed && (
                    <button aria-label="Display Settings" class="btn-plain scale-animation rounded-lg h-11 w-11 active:scale-90" id="display-settings-switch">
                        <Icon name="material-symbols:palette-outline" class="text-[1.25rem]"></Icon>
                    </button>
            )}
            <LightDarkSwitch client:load></LightDarkSwitch>
            <button aria-label="Menu" name="Nav Menu" class="btn-plain scale-animation rounded-lg w-11 h-11 active:scale-90 md:!hidden" id="nav-menu-switch">
                <Icon name="material-symbols:menu-rounded" class="text-[1.25rem]"></Icon>
            </button>
        </div>
        <NavMenuPanel links={links}></NavMenuPanel>
        <DisplaySettings client:only="svelte"></DisplaySettings>
    </div>
</div>

<script>
function switchTheme() {
    if (localStorage.theme === 'dark') {
        document.documentElement.classList.remove('dark');
        localStorage.theme = 'light';
    } else {
        document.documentElement.classList.add('dark');
        localStorage.theme = 'dark';
    }
}

function loadButtonScript() {
    let switchBtn = document.getElementById("scheme-switch");
    if (switchBtn) {
        switchBtn.onclick = function () {
            switchTheme()
        };
    }

    let settingBtn = document.getElementById("display-settings-switch");
    if (settingBtn) {
        settingBtn.onclick = function () {
            let settingPanel = document.getElementById("display-setting");
            if (settingPanel) {
                settingPanel.classList.toggle("float-panel-closed");
            }
        };
    }

    let menuBtn = document.getElementById("nav-menu-switch");
    if (menuBtn) {
        menuBtn.onclick = function () {
            let menuPanel = document.getElementById("nav-menu-panel");
            if (menuPanel) {
                menuPanel.classList.toggle("float-panel-closed");
            }
        };
    }
}

const bangumiSnapshotCacheKey = "bangumi:snapshot:v1";
const bangumiSnapshotApiUrl = "/bangumi/bangumi.json";
const bangumiSnapshotPromiseMaxAge = 30 * 1000;

function isBangumiSnapshot(value: unknown): value is BangumiSnapshot {
    return Boolean(
        typeof value === "object"
        && value !== null
        && Array.isArray((value as { collections?: unknown }).collections)
    );
}

function hasBangumiSnapshotItems(snapshot: unknown) {
    return isBangumiSnapshot(snapshot)
        && snapshot.collections.some((group) => Array.isArray(group.list) && group.list.length > 0);
}

function readBangumiSnapshotCache() {
    try {
        const raw = localStorage.getItem(bangumiSnapshotCacheKey);
        if (!raw) return undefined;
        const snapshot = JSON.parse(raw);
        return isBangumiSnapshot(snapshot) ? snapshot : undefined;
    } catch {
        return undefined;
    }
}

function writeBangumiSnapshotCache(snapshot: BangumiSnapshot) {
    try {
        localStorage.setItem(bangumiSnapshotCacheKey, JSON.stringify(snapshot));
    } catch {
        // Ignore storage quota/private browsing failures.
    }
}

function getReusableBangumiSnapshotPromise() {
    const promise = window.__bangumiSnapshotPromise;
    const startedAt = Number(window.__bangumiSnapshotPromiseStartedAt || 0);

    if (promise && startedAt && Date.now() - startedAt < bangumiSnapshotPromiseMaxAge) {
        return promise;
    }

    return undefined;
}

function warmBangumiSnapshot() {
    const existing = getReusableBangumiSnapshotPromise();
    if (existing) return existing;

    const request = fetch(bangumiSnapshotApiUrl, {
        headers: {
            Accept: "application/json",
        },
    }).then((response) => {
        if (!response.ok) {
            throw new Error(`Bangumi snapshot warmup failed: ${response.status}`);
        }

        return response.json();
    }).then((payload: BangumiSnapshotPayload) => {
        if (isBangumiSnapshot(payload?.snapshot)) {
            writeBangumiSnapshotCache(payload.snapshot);
            document.dispatchEvent(new CustomEvent("bangumi:snapshot-ready", {
                detail: payload.snapshot,
            }));
        }

        return payload;
    });

    window.__bangumiSnapshotPromiseStartedAt = Date.now();
    window.__bangumiSnapshotPromise = request.catch((error) => {
        window.__bangumiSnapshotPromise = undefined;
        window.__bangumiSnapshotPromiseStartedAt = 0;
        throw error;
    });

    return window.__bangumiSnapshotPromise;
}

window.__warmBangumiSnapshot = warmBangumiSnapshot;

function isBangumiLink(link: HTMLAnchorElement) {
    const href = link.getAttribute("href");
    if (!href) return false;

    try {
        const target = new URL(href, window.location.origin);
        return target.origin === window.location.origin && target.pathname === "/bangumi/";
    } catch {
        return href === "/bangumi/";
    }
}

function bindBangumiWarmupTriggers(root: ParentNode = document) {
    const links = root.querySelectorAll("a[href]");
    const startWarmup = () => {
        warmBangumiSnapshot().catch(() => undefined);
    };

    for (const link of links) {
        if (!(link instanceof HTMLAnchorElement)) continue;
        if (!isBangumiLink(link) || link.dataset.bangumiWarmupBound === "true") continue;

        link.dataset.bangumiWarmupBound = "true";
        link.addEventListener("pointerenter", startWarmup, { passive: true });
        link.addEventListener("focusin", startWarmup);
        link.addEventListener("touchstart", startWarmup, { passive: true });
        link.addEventListener("pointerdown", startWarmup, { passive: true });
    }
}

function scheduleBangumiSnapshotWarmup() {
    if (window.location.pathname === "/bangumi/") return;

    const warmupIfMissing = () => {
        if (hasBangumiSnapshotItems(readBangumiSnapshotCache())) return;

        const runWarmup = () => {
            warmBangumiSnapshot().catch(() => undefined);
        };

        if ("requestIdleCallback" in window) {
            window.requestIdleCallback(runWarmup, { timeout: 2500 });
        } else {
            setTimeout(runWarmup, 1200);
        }
    };

    if (document.documentElement.classList.contains("entry-ready")) {
        setTimeout(warmupIfMissing, 800);
    } else {
        document.addEventListener("blog:entry-ready", () => {
            setTimeout(warmupIfMissing, 800);
        }, { once: true });
    }
}

function setupBangumiSnapshotWarmup() {
    bindBangumiWarmupTriggers();
    scheduleBangumiSnapshotWarmup();

    const bindAfterSwupPageView = () => {
        window.swup?.hooks?.on("page:view", () => bindBangumiWarmupTriggers());
    };

    if (window.swup?.hooks) {
        bindAfterSwupPageView();
    } else {
        document.addEventListener("swup:enable", bindAfterSwupPageView, { once: true });
    }
}

loadButtonScript();
if (!window.__bangumiSnapshotWarmupSetup) {
    window.__bangumiSnapshotWarmupSetup = true;
    setupBangumiSnapshotWarmup();
}
</script>

{import.meta.env.PROD && <script is:inline define:vars={{scriptUrl: pagefindScriptUrl}}>
async function loadPagefind() {
    if (window.pagefind && typeof window.pagefind.search === 'function') {
        document.dispatchEvent(new CustomEvent('pagefindready'));
        return window.pagefind;
    }
    if (window.__pagefindLoadPromise) {
        return window.__pagefindLoadPromise;
    }

    window.__pagefindLoadPromise = (async () => {
    try {
        const pagefind = await import(scriptUrl);

        await pagefind.options({
            excerptLength: 20,
            noWorker: true
        });
        await pagefind.init?.();

        window.pagefind = pagefind;

        document.dispatchEvent(new CustomEvent('pagefindready'));
        return pagefind;

    } catch (error) {
        console.error('Failed to load Pagefind:', error);
        window.__pagefindLoadPromise = undefined;
        document.dispatchEvent(new CustomEvent('pagefindloaderror'));
        return null;

    }
    })();

    return window.__pagefindLoadPromise;
}

window["loadPagefind"] = loadPagefind;

function bindPagefindTriggers() {
    const triggerSelectors = [
        '#search-bar',
        '#search-switch',
        '#search-panel',
        '#search-bar-inside',
    ];

    for (const selector of triggerSelectors) {
        const el = document.querySelector(selector);
        if (!el) continue;
        el.addEventListener('pointerenter', loadPagefind, { once: true, passive: true });
        el.addEventListener('focusin', loadPagefind, { once: true });
        el.addEventListener('click', loadPagefind, { once: true, passive: true });
    }
}

function schedulePagefindWarmup() {
    const warmup = () => {
        if (
            window.__pagefindLoadPromise ||
            (window.pagefind && typeof window.pagefind.search === 'function')
        ) {
            return;
        }

        window.setTimeout(loadPagefind, 250);
    };

    if (document.documentElement.classList.contains('entry-ready')) {
        warmup();
    } else {
        document.addEventListener('blog:entry-ready', warmup, {once: true});
    }
}

function setupPagefindLoader() {
    bindPagefindTriggers();
    schedulePagefindWarmup();
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupPagefindLoader);
} else {
    setupPagefindLoader();
}
</script>}
